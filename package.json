{
  "name": "dinnerparty",
  "version": "0.1.0",
  "private": true,
  "description": "Recipe storage platform for chefs and home cooks",
  "workspaces": [
    "client",
    "server"
  ],
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "mermaid": "^11.14.0",
    "pdfmake": "^0.3.7"
  },
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm run lint -w client && npm run lint -w dinnerparty-server",
    "lint:fix": "npm run lint:fix -w client && npm run lint:fix -w dinnerparty-server"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,mjs,json,css,md}": "prettier --write",
    "client/**/*.{ts,tsx}": "eslint --fix --config client/eslint.config.js",
    "server/**/*.ts": "eslint --fix --config server/eslint.config.mjs"
  },
  "devDependencies": {
    "@types/pdfmake": "^0.3.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  }
}
